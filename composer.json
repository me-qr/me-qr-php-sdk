    "description": "Official PHP SDK for the ME-QR API",
    "type": "library",
    "license": "MIT",
    "keywords": ["qr", "qr-code", "me-qr", "api", "sdk"],
    "homepage": "https://me-qr.com",
    "authors": [
        {
            "name": "ME-QR",
            "homepage": "https://me-qr.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "autoload": {
